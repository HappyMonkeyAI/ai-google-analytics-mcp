# Google Cloud / GA4 credentials (pick one path — see research/notes/gcloud-this-app-is-blocked.md)

# --- Path A (recommended for Hermes / MCP): service account JSON ---
# 1. GCP: IAM → Service Accounts → create key → download JSON (never commit)
# 2. GA: Admin → Account/Property Access Management → add service account email as Editor
# 3. Point ADC at the key:
GOOGLE_APPLICATION_CREDENTIALS=/home/user/.config/ga4/ga4-provisioner-sa.json

# --- Path B: user ADC via gcloud (often blocked on Workspace for analytics.edit) ---
# gcloud auth application-default login --scopes ...

# Optional defaults for provisioning tools
GA4_DEFAULT_ACCOUNT_ID=
GA4_DEFAULT_TIMEZONE=Europe/London
GA4_DEFAULT_CURRENCY=GBP

# GCP project id (companion analytics-mcp / quota)
CLOUDSDK_CORE_PROJECT=

# Optional: launcher-project-registry JSON (read-only by default)
# GA4_LAUNCHER_REGISTRY_JSON=/path/to/registry.json
# GA4_LAUNCHER_REGISTRY_WRITABLE=true

# Optional: keymaster host hints (compose keymaster MCP separately for secrets)
# GA4_KEYMASTER_DATABASE=/path/to/keymaster.db
# GA4_KEYMASTER_HINTS=true